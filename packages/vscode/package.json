{
  "name": "agentctl",
  "displayName": "agentctl",
  "description": "Gate and trace dangerous agent actions — approve escalations and browse traces from VS Code",
  "version": "0.1.0",
  "publisher": "agentctl",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "keywords": ["agent", "ai", "safety", "policy", "mcp"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentctl",
          "title": "agentctl",
          "icon": "resources/agentctl.svg"
        }
      ]
    },
    "views": {
      "agentctl": [
        {
          "id": "agentctl.approvals",
          "name": "Pending Approvals"
        },
        {
          "id": "agentctl.traces",
          "name": "Recent Traces"
        }
      ]
    },
    "commands": [
      {
        "command": "agentctl.approve",
        "title": "Approve",
        "icon": "$(check)"
      },
      {
        "command": "agentctl.deny",
        "title": "Deny",
        "icon": "$(x)"
      },
      {
        "command": "agentctl.refreshApprovals",
        "title": "Refresh Approvals",
        "icon": "$(refresh)"
      },
      {
        "command": "agentctl.refreshTraces",
        "title": "Refresh Traces",
        "icon": "$(refresh)"
      },
      {
        "command": "agentctl.startServer",
        "title": "agentctl: Start Server"
      },
      {
        "command": "agentctl.stopServer",
        "title": "agentctl: Stop Server"
      },
      {
        "command": "agentctl.toggleServer",
        "title": "agentctl: Toggle Server"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentctl.refreshApprovals",
          "when": "view == agentctl.approvals",
          "group": "navigation"
        },
        {
          "command": "agentctl.refreshTraces",
          "when": "view == agentctl.traces",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "agentctl.approve",
          "when": "view == agentctl.approvals && viewItem == pending",
          "group": "inline@1"
        },
        {
          "command": "agentctl.deny",
          "when": "view == agentctl.approvals && viewItem == pending",
          "group": "inline@2"
        }
      ]
    },
    "configuration": {
      "title": "agentctl",
      "properties": {
        "agentctl.serverUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8080",
          "description": "URL of the agentctl HTTP server"
        },
        "agentctl.authToken": {
          "type": "string",
          "default": "",
          "description": "Bearer auth token for the agentctl server (leave blank for loopback)"
        },
        "agentctl.pollIntervalMs": {
          "type": "number",
          "default": 5000,
          "minimum": 1000,
          "description": "How often to poll for new pending approvals (milliseconds)"
        },
        "agentctl.autoStartServer": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start 'agentctl serve' when VS Code opens"
        },
        "agentctl.tracesLimit": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "description": "Maximum number of traces to show in the Traces view"
        }
      }
    }
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --target=node18 --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --target=node18 --sourcemap --watch",
    "package": "npm run compile && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.24.0"
  }
}
